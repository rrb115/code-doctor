{
  "name": "code-doctor",
  "version": "0.0.18",
  "description": "Detect and eliminate unnecessary LLM calls in JS/TS codebases — replace with deterministic logic",
  "keywords": [
    "llm",
    "ai",
    "diagnostics",
    "linter",
    "performance",
    "deterministic"
  ],
  "homepage": "https://github.com/rrb115/code-doctor#readme",
  "bugs": {
    "url": "https://github.com/rrb115/code-doctor/issues"
  },
  "license": "MIT",
  "author": "Rajat Bhatnagar",
  "repository": {
    "type": "git",
    "url": "https://github.com/rrb115/code-doctor.git",
    "directory": "packages/react-doctor"
  },
  "bin": {
    "code-doctor": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./api": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./oxlint-plugin": {
      "types": "./dist/code-doctor-plugin.d.ts",
      "default": "./dist/code-doctor-plugin.js"
    }
  },
  "scripts": {
    "dev": "tsdown --watch",
    "build": "rm -rf dist && NODE_ENV=production tsdown",
    "typecheck": "tsc --noEmit",
    "test": "pnpm build && vitest run"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "knip": "^5.83.1",
    "ora": "^9.3.0",
    "oxlint": "^1.47.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2",
    "typescript": ">=5.0.4 <7"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "tsdown": "^0.20.3"
  }
}